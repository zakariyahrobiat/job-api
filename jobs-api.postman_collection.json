    {
      "name": "create job",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "const jsonData = pm.response.json()\r",
              "\r",
              "pm.globals.set(\"id\", jsonData.job._id);"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "auth": {
          "type": "bearer",
          "bearer": [
            {
              "key": "token",
              "value": "{{accessToken}}",
              "type": "string"
            }
          ]
        },
        "method": "POST",

        "body": {
          "mode": "raw",
          "raw": "{\r\n    \"company\":\"facebook\",\"position\":\"frontend\"\r\n}",
